<% 
    title = "New Drive"
    layout('./layouts/boilerplate.ejs') 
%>
<link rel="stylesheet" href="/CSS/style.css">
<form class="container" id="multiStepForm" method="post" action="/drive">
    <!-- Step 1 -->
    <div id="step1">
        <div class="form-group">
            <label for="companyName">Company Name:</label>
            <input type="text" class="form-control" id="companyName" name="companyName" required>
        </div>

        <div class="form-group">
            <label for="driveDate">Drive Date:</label>
            <input type="date" class="form-control" id="driveDate" name="driveDate" required>
        </div>

        <div class="form-group">
            <label for="jobDescription">Job Description:</label>
            <textarea class="form-control" id="jobDescription" name="jobDescription" rows="4" required></textarea>
        </div>

        <div class="form-group">
            <label for="jobCriteria">Job Criteria:</label>
            <textarea class="form-control" id="jobCriteria" name="jobCriteria" rows="4" required></textarea>
        </div>
        <div class="form-group">
            <label for="salaryRange">Salary Range:</label>
            <input type="text" class="form-control" id="salaryRange" name="salaryRange" required>
        </div>
        <div class="form-group">
            <label for="eligibilityCriteria">Eligibility Criteria:</label>
            <textarea class="form-control" id="eligibilityCriteria" name="eligibilityCriteria" rows="4"
                required></textarea>
        </div>
        <div class="form-group">
            <label for="location">Location</label>
            <input class="form-control" id="location" name="location" required>
        </div>
        <!-- Other Step 1 fields -->
        <div class="button-container">
            <button type="button" class="btn btn-primary" onclick="nextStep('step1')">Next</button>

        </div>
    </div>

    <!-- Step 2 -->
    <div id="step2" style="display: none;">

        <div class="form-group">
            <label for="selectionProcess">Selection Process:</label>
            <textarea class="form-control" id="selectionProcess" name="selectionProcess" rows="4" required></textarea>
        </div>

        <div class="form-group">
            <label for="skillsRequired">Skills Required:</label>
            <input type="text" class="form-control" id="skillsRequired" name="skillsRequired" required>
        </div>

        <div class="form-group">
            <label for="internshipOpportunities">Internship Opportunities:</label>
            <select class="form-control" id="internshipOpportunities" name="internshipOpportunities" required>
                <option value="yes">Yes</option>
                <option value="no">No</option>
            </select>
        </div>

        <div class="form-group">
            <label for="contactEmail">Contact Email:</label>
            <input type="email" class="form-control" id="contactEmail" name="contactEmail" required>
        </div>

        <div class="form-group">
            <label for="contactNumber">Contact Number:</label>
            <input type="tel" class="form-control" id="contactNumber" name="contactNumber" required>
        </div>

        <div class="form-group">
            <label for="companyDescription">Company Description:</label>
            <textarea class="form-control" id="companyDescription" name="companyDescription" rows="4"
                required></textarea>
        </div>
        <!-- Other Step 2 fields -->

        <div class="button-container">
            <button type="button" class="btn btn-primary" onclick="prevStep('step2')">Previous</button>
            <button type="submit" class="btn btn-info">Submit</button>
        </div>
    </div>
</form>